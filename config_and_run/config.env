# 服务器一键实验配置模板。
# 使用前复制为 config.env，并至少填写 WANDB_API_KEY。

# 基础路径。默认把模型、数据、checkpoint、日志都放在项目根目录下的 save/。
SAVE_DIR="${REPO_ROOT}/save"
CONDA_ENV_NAME="aer"
CUDA_VISIBLE_DEVICES="0,1,2,3"
N_GPUS_PER_NODE=4

# Hugging Face / pip 镜像。国内服务器建议保留 HF_ENDPOINT。
HF_ENDPOINT="https://hf-mirror.com"
HF_TOKEN=""
PIP_INDEX_URL=""
PIP_EXTRA_INDEX_URL=""

# wandb 配置。WANDB_API_KEY 不要提交到 Git，只写在本地 config.env。
WANDB_MODE="online"
WANDB_API_KEY="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"
WANDB_ENTITY=""
WANDB_PROJECT="AER"

# 模型配置。MODEL_PATH 是最终本地路径；脚本会在 DOWNLOAD_MODELS=1 时自动下载。
POLICY_MODEL_REPO="Qwen/Qwen3-4B"
POLICY_MODEL_REVISION="main"
MODEL_PATH="${SAVE_DIR}/models/Qwen/Qwen3-4B"

# embedding 模型仅在启用 semantic_embedding 训练或 semantic-cosine 评测时需要。
EMBEDDING_MODEL_REPO="Qwen/Qwen3-Embedding-0.6B"
EMBEDDING_MODEL_REVISION="main"
EMBEDDING_MODEL_PATH="${SAVE_DIR}/models/Qwen/Qwen3-Embedding-0.6B"
DOWNLOAD_EMBEDDING_MODEL=0

# 数据配置。DATA_REPO_PREFIX 为空时直接从 HF Hub / HF_ENDPOINT 下载。
DATA_REPO_PREFIX=""
DATA_REPEAT=1
DATA_SOURCES="DigitalLearningGmbH/MATH-lighteval math-ai/math500 math-ai/amc23 math-ai/aime24 math-ai/aime25"

# 服务器默认分工：跑轻量 AER 算法的校准 + 三档 tau 正式实验。
# 如需语义相似度实验，再手动追加 semantic_embedding。
EXPERIMENT_ALGORITHMS="ngram_overlap simhash levenshtein"
CALIBRATION_STEPS=72
TOTAL_TRAINING_STEPS=240

# 如果还没有确定 S_final，又希望一次跑够可比较 checkpoint，
# 可以在启动前把 TOTAL_TRAINING_STEPS 改成 320。
TEST_FREQ=12
SAVE_FREQ=24
MAX_ACTOR_CKPT_TO_KEEP=6
MAX_CRITIC_CKPT_TO_KEEP=6

# 如需让顺便跑额外熵正则 baseline，在这里填系数，例如 "5e-4 2e-3"。
# 默认留空，因为当前熵正则 baseline 由你另一台服务器负责。
ENTROPY_BASELINE_COEFFS=""

# 训练公共超参数，默认对齐当前 run.sh。
TRAIN_BATCH_SIZE=128
PPO_MINI_BATCH_SIZE=32
MAX_PROMPT_LENGTH=2048
MAX_RESPONSE_LENGTH=4096
MAX_TOKEN_LEN_PER_GPU=16384
ROLLOUT_N=16
LR=1e-6
WEIGHT_DECAY=0.0
TEMPERATURE=1.0
TOP_P=1.0
GPU_MEMORY_UTILIZATION=0.9
TENSOR_MODEL_PARALLEL_SIZE=1
VAL_KWARGS_N=8
VAL_KWARGS_TEMPERATURE=0.6
VAL_KWARGS_TOP_P=0.95
VAL_KWARGS_TOP_K=20
VAL_BEFORE_TRAIN=False

# 相似度计算配置。
SIMILARITY_N=3
SIMILARITY_BATCH_SIZE=128
SIMILARITY_MAX_LENGTH=4096
SIMILARITY_DEVICE="cpu"
SIMILARITY_NUM_PROCESSES=4

# CPU 线程配置。服务器 CPU 核数较少时建议降低到 8 或 16。
OMP_NUM_THREADS=32
MKL_NUM_THREADS=32
OPENBLAS_NUM_THREADS=32
NUMEXPR_NUM_THREADS=32
VECLIB_MAXIMUM_THREADS=32
TORCH_NUM_THREADS=32
RAY_TMPDIR="${HOME}/rt"
RAY_NUM_CPUS=""

# 流程开关。
DOWNLOAD_MODELS=1
PREPARE_DATA=1
RUN_SMOKE_TESTS=1
RUN_EVAL_AFTER_TRAIN=1
INSTALL_OPTIONAL_DEPS=1
STOP_RAY_BETWEEN_RUNS=1
FORCE_RERUN=0
DRY_RUN=0

# JSONL 离线评测配置。默认不计算 semantic-cosine，避免额外 embedding 推理耗时。
EVAL_LAST_STEP_ONLY=1
EVAL_METRICS="pass@k,first@1,distinct-2,self-bleu"
EVAL_KS="1,2,4,8"
