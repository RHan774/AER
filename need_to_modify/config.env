# AER 新实验一键运行配置。
# 使用前至少确认 PRIMUS_OUTPUT_DIR、WANDB_API_KEY、MODEL_PATH、DATA_DIR、EMBEDDING_MODEL_PATH 和 GPU 编号。

# =========================
# 最常修改的本机配置
# =========================

# 训练输出根目录。可以直接改这里，也可以在运行命令前 export PRIMUS_OUTPUT_DIR 覆盖。
PRIMUS_OUTPUT_DIR="${PRIMUS_OUTPUT_DIR:-}"

# 1_run.sh 和 2_run.sh 的 GPU 分配。默认把 16 张卡拆成两组，每个脚本各用 8 张。
# 如果要改成其他机器布局，优先改这里；脚本会自动同步训练、相似度计算和正式评测用卡。
RUN_1_CUDA_VISIBLE_DEVICES="${RUN_1_CUDA_VISIBLE_DEVICES:-0,1,2,3,4,5,6,7}"
RUN_1_N_GPUS_PER_NODE="${RUN_1_N_GPUS_PER_NODE:-8}"
RUN_1_SIMILARITY_CUDA_VISIBLE_DEVICES="${RUN_1_SIMILARITY_CUDA_VISIBLE_DEVICES:-[${RUN_1_CUDA_VISIBLE_DEVICES}]}"
RUN_1_SIMILARITY_NUM_PROCESSES="${RUN_1_SIMILARITY_NUM_PROCESSES:-${RUN_1_N_GPUS_PER_NODE}}"
RUN_1_FORMAL_EVAL_GPUS="${RUN_1_FORMAL_EVAL_GPUS:-${RUN_1_CUDA_VISIBLE_DEVICES}}"

RUN_2_CUDA_VISIBLE_DEVICES="${RUN_2_CUDA_VISIBLE_DEVICES:-0,1,2,3,4,5,6,7}"
RUN_2_N_GPUS_PER_NODE="${RUN_2_N_GPUS_PER_NODE:-8}"
RUN_2_SIMILARITY_CUDA_VISIBLE_DEVICES="${RUN_2_SIMILARITY_CUDA_VISIBLE_DEVICES:-[${RUN_2_CUDA_VISIBLE_DEVICES}]}"
RUN_2_SIMILARITY_NUM_PROCESSES="${RUN_2_SIMILARITY_NUM_PROCESSES:-${RUN_2_N_GPUS_PER_NODE}}"
RUN_2_FORMAL_EVAL_GPUS="${RUN_2_FORMAL_EVAL_GPUS:-${RUN_2_CUDA_VISIBLE_DEVICES}}"

# 基础路径。REPO_ROOT 由脚本在 source 本文件前注入。
# SAVE_DIR 是训练输出根目录；训练产生的 checkpoints、validation、eval、日志和临时文件都放到这里。
SAVE_DIR="${PRIMUS_OUTPUT_DIR:?请先设置 PRIMUS_OUTPUT_DIR 作为训练输出目录}"
OUTPUT_DIR="${SAVE_DIR}"
INFERENCE_CKPT_DIR="${INFERENCE_CKPT_DIR:-${SAVE_DIR}/inference_checkpoints}"
# DATA_DIR 只放 parquet 数据集。直接运行 1_run.sh / 2_run.sh 时默认读取仓库 save/data 下的数据。
DATA_DIR="${DATA_DIR:-${REPO_ROOT}/save/data}"
CONDA_ENV_NAME="aer"
# 直接运行 run_experiments.sh 时使用的默认 GPU；1_run.sh / 2_run.sh 会使用上方各自的 RUN_* 配置覆盖。
CUDA_VISIBLE_DEVICES="${CUDA_VISIBLE_DEVICES:-${RUN_1_CUDA_VISIBLE_DEVICES}}"
N_GPUS_PER_NODE="${N_GPUS_PER_NODE:-${RUN_1_N_GPUS_PER_NODE}}"

# Hugging Face / pip 镜像。国内服务器建议保留 HF_ENDPOINT。
HF_ENDPOINT="https://hf-mirror.com"
HF_TOKEN=""
PIP_INDEX_URL=""
PIP_EXTRA_INDEX_URL=""

# wandb 配置。WANDB_API_KEY 不要提交到 Git，只写在本地 config.env。
WANDB_MODE="online"
WANDB_API_KEY="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"
WANDB_ENTITY=""
WANDB_PROJECT="AER"

# 模型配置。默认训练超参与 verl/recipe/aer/run.sh 对齐；路径可按服务器实际磁盘修改。
POLICY_MODEL_REPO="Qwen/Qwen3-4B-Base"
POLICY_MODEL_REVISION="main"
MODEL_PATH="/primus_datasets/primus_data/Skill_SP_08zY9v/Qwen3-4B-Base"

# embedding 模型仅在 semantic_embedding 训练或 semantic-cosine 评测时需要。
EMBEDDING_MODEL_REPO="Qwen/Qwen3-Embedding-0.6B"
EMBEDDING_MODEL_REVISION="main"
EMBEDDING_MODEL_PATH="/primus_datasets/primus_data/Skill_SP_08zY9v/Qwen3-Embedding-0.6B"
DOWNLOAD_EMBEDDING_MODEL=0

# 数据配置。DATA_REPO_PREFIX 为空时直接从 HF Hub / HF_ENDPOINT 下载，准备好的 parquet 写入 DATA_DIR。
DATA_REPO_PREFIX=""
DATA_REPEAT=1
DATA_SOURCES="DigitalLearningGmbH/MATH-lighteval math-ai/math500 math-ai/amc23 math-ai/aime24 math-ai/aime25"

# =========================
# 训练实验矩阵
# =========================

# T0：tau=0 naive GRPO 校准 baseline。会同时记录下列算法的探索奖励，不参与训练目标。
RUN_BASELINE_NAIVE=0
CALIBRATION_METRIC_ALGORITHMS="token_match ngram_overlap semantic_embedding simhash"
CALIBRATION_STEPS=360
# T0 中耗时较大的算法延后到最后 CALIBRATION_DELAY_FRACTION 步才开始记录，节省前期计算。
CALIBRATION_DELAYED_ALGORITHMS="semantic_embedding"
CALIBRATION_DELAY_FRACTION=0.10

# T1：熵正则 mean baseline。熵的 mean 聚合在代码中实现，这里只控制是否运行和系数。
RUN_BASELINE_ENTROPY=0
ENTROPY_BASELINE_COEFF="0.015"

# T2-T5：选一个算法做 gamma 搜索。
RUN_GAMMA_SEARCH=0
TARGET_SIMILARITY_FOR_GAMMA_SEARCH="ngram_overlap"
GAMMA_LIST="1.1 1.2 1.3 1.4"
GAMMA_BEST="auto"
GAMMA_SELECTION_PRIMARY_METRIC="pass@16" # 主排序指标
GAMMA_SELECTION_TIEBREAK_METRIC="correct_rate"  # 打平时的次要指标
TAU_PRECISION=6

# T6-T8：复用 gamma_best 跑主 AER 实验。若目标算法已在 gamma 搜索中跑过最佳 gamma，则默认复用该 run。
RUN_MAIN_AER=0
MAIN_SIMILARITY_ALGORITHMS="token_match ngram_overlap semantic_embedding"
REUSE_GAMMA_SEARCH_FOR_TARGET=1

# T9：时间充足时再跑的补充算法。
RUN_EXTRA_AER=0
EXTRA_SIMILARITY_ALGORITHMS="simhash"

# 所有训练实验的公共预算，默认对齐 run.sh。
TOTAL_TRAINING_STEPS=360
TEST_FREQ=12
SAVE_FREQ=12
MAX_ACTOR_CKPT_TO_KEEP=3
MAX_CRITIC_CKPT_TO_KEEP=3

# 训练公共超参数，默认对齐当前 run.sh。
TRAIN_BATCH_SIZE=128
PPO_MINI_BATCH_SIZE=32
MAX_PROMPT_LENGTH=2048
MAX_RESPONSE_LENGTH=4096
MAX_TOKEN_LEN_PER_GPU=16384
ROLLOUT_N=16
LR=1e-6
WEIGHT_DECAY=0.0
TEMPERATURE=1.0
TOP_P=1.0
GPU_MEMORY_UTILIZATION=0.9
TENSOR_MODEL_PARALLEL_SIZE=1
VAL_KWARGS_N=16
VAL_KWARGS_TEMPERATURE=0.6
VAL_KWARGS_TOP_P=0.95
VAL_KWARGS_TOP_K=20
VAL_BEFORE_TRAIN=False

# 相似度计算配置。
# semantic_embedding 可通过 SIMILARITY_DEVICE 选择 CPU 或 GPU：
#   CPU:  SIMILARITY_DEVICE="cpu"，SIMILARITY_CUDA_VISIBLE_DEVICES=""
#   默认: SIMILARITY_DEVICE="cuda"，SIMILARITY_CUDA_VISIBLE_DEVICES 自动使用 CUDA_VISIBLE_DEVICES 表示的同一组 GPU
#   单卡: CUDA_VISIBLE_DEVICES="4"，SIMILARITY_NUM_PROCESSES=1
#   多卡: CUDA_VISIBLE_DEVICES="0,1,2,3,4,5,6,7"，SIMILARITY_NUM_PROCESSES=8
BASELINE_SIMILARITY_ALGORITHM="token_match"
SIMILARITY_N=3
SIMILARITY_BATCH_SIZE=32
SIMILARITY_MAX_LENGTH=4096
SIMILARITY_TAIL_TOKENS=4096
SIMILARITY_DEVICE="cuda"
SIMILARITY_CUDA_VISIBLE_DEVICES="[${CUDA_VISIBLE_DEVICES}]"
SIMILARITY_NUM_PROCESSES="${SIMILARITY_NUM_PROCESSES:-${N_GPUS_PER_NODE}}"
SIMILARITY_NORMALIZE_METHOD="max"
SIMILARITY_MAX_FEATURES=1000
SIMILARITY_MIN_DF=1
SIMILARITY_MAX_DF=1.0
SIMILARITY_NGRAM_RANGE="[1,2]"
SIMILARITY_HASH_BITS=64
SIMILARITY_USE_COUNTS=true
SIMILARITY_CALIBRATE_RANDOM=true

# CPU 线程配置，默认对齐 run.sh 中的 embedding worker 设置。
OMP_NUM_THREADS=48
MKL_NUM_THREADS=48
OPENBLAS_NUM_THREADS=48
NUMEXPR_NUM_THREADS=48
VECLIB_MAXIMUM_THREADS=48
TORCH_NUM_THREADS=48
RAY_TMPDIR="${SAVE_DIR}/ray_tmp"
RAY_NUM_CPUS=""

# 流程开关。
DOWNLOAD_MODELS=1
PREPARE_DATA=1
RUN_SMOKE_TESTS=1
RUN_EVAL_AFTER_TRAIN=1
INSTALL_OPTIONAL_DEPS=1
MATCH_CURRENT_ENV_AFTER_CREATE=1
# 并行 nohup 跑 1_run.sh 和 2_run.sh 时保持为 0，避免一个脚本 ray stop 杀掉另一个脚本。
STOP_RAY_BETWEEN_RUNS=0
FORCE_RERUN=0
DRY_RUN=0

# 训练期间后台 watcher 实时评测每一步 validation JSONL，纯 CPU 不占 GPU。
AFTER_TRAIN_EVAL_METRICS="pass@k,first@1,distinct-2,self-bleu,equational-diversity"
AFTER_TRAIN_EVAL_KS="1,2,4,8"
AFTER_TRAIN_EVAL_SEMANTIC_DEVICE="cpu"
AFTER_TRAIN_EVAL_SEMANTIC_BATCH_SIZE=32
AFTER_TRAIN_EVAL_SEMANTIC_MAX_LENGTH=1024

# =========================
# 正式完整评测配置
# =========================
# 这组配置只给 run_eval_formal_checkpoints.sh 使用，和训练后轻量评测分开。

FORMAL_EVAL_EXPERIMENT_NAMES=""
FORMAL_EVAL_EXTRA_EXPERIMENT_NAMES=""
FORMAL_EVAL_INCLUDE_BASELINE_NAIVE=1
FORMAL_EVAL_INCLUDE_BASELINE_ENTROPY=1
FORMAL_EVAL_INCLUDE_GAMMA_SEARCH="best"
FORMAL_EVAL_MAIN_ALGORITHMS="${MAIN_SIMILARITY_ALGORITHMS}"
FORMAL_EVAL_REUSE_GAMMA_SEARCH_FOR_TARGET="${REUSE_GAMMA_SEARCH_FOR_TARGET}"

FORMAL_EVAL_CHECKPOINT_STEP="${TOTAL_TRAINING_STEPS}"
FORMAL_EVAL_GPUS="${CUDA_VISIBLE_DEVICES}"
FORMAL_EVAL_METRICS="pass@k,first@1,distinct-2,self-bleu,semantic-cosine,equational-diversity"
FORMAL_EVAL_KS="1,2,4,8,16,32,64,128"
FORMAL_EVAL_SAMPLES_PER_PROMPT=128
FORMAL_EVAL_OUTPUT_SUBDIR="formal_pass128_sharded"
# 留空时自动使用 FORMAL_EVAL_GPUS 对应的 cuda 设备；设为 "cpu" 可强制 CPU 计算。
FORMAL_EVAL_SEMANTIC_DEVICE=""
FORMAL_EVAL_SEMANTIC_BATCH_SIZE=128
FORMAL_EVAL_SEMANTIC_MAX_LENGTH=4096
FORMAL_EVAL_ROLLOUT_SAVE_BATCH_SIZE=8
FORMAL_EVAL_BACKEND="vllm"
FORMAL_EVAL_GPU_MEMORY_UTILIZATION="${GPU_MEMORY_UTILIZATION}"
FORMAL_EVAL_VLLM_MAX_MODEL_LEN=$((MAX_PROMPT_LENGTH + MAX_RESPONSE_LENGTH))
FORMAL_EVAL_VLLM_MAX_NUM_SEQS=256
FORMAL_EVAL_VLLM_MAX_NUM_BATCHED_TOKENS=65536
FORMAL_EVAL_MAX_NEW_TOKENS="${MAX_RESPONSE_LENGTH}"
FORMAL_EVAL_TEMPERATURE="${VAL_KWARGS_TEMPERATURE}"
FORMAL_EVAL_TOP_P="${VAL_KWARGS_TOP_P}"
FORMAL_EVAL_TOP_K="${VAL_KWARGS_TOP_K}"
FORMAL_EVAL_SEED=42
FORMAL_EVAL_FORCE_MERGE=0
